<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
  <main>
    <div class="page-header">
      <div class="page-header-left">
        <span class="page-label">Supply Chain</span>
        <h1>Vendors</h1>
      </div>
      <div style="display:flex;gap:12px;align-items:center;">
        <% if(vendors && vendors.length){ %>
          <span class="count-badge"><%= vendors.length %> vendors</span>
        <% } %>
        <a href="/vendors/create" class="btn btn-primary">+ Add Vendor</a>
      </div>
    </div>

    <% if(vendors && vendors.length){ %>
      <div class="cards-grid" id="vendors-container">
        <% vendors.forEach(vendor => { %>
          <div class="card">
            <div class="card-name"><%= vendor.name %></div>
            <div class="card-meta">
              <span class="tag"><%= vendor.location || 'No location' %></span>
            </div>
            <div class="card-actions">
              <a href="/vendors/<%= vendor.id %>/update" class="btn btn-ghost btn-sm">Edit</a>
              <a href="/vendors/<%= vendor.id %>/add-product" class="btn btn-ghost btn-sm">+ Product</a>
              <a href="/vendors/<%= vendor.id %>/adjust-stock" class="btn btn-ghost btn-sm">Stock</a>
              <button class="btn btn-danger btn-sm del-vendor-btn" data-id="<%= vendor.id %>">Delete</button>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty">No vendors yet — add one to get started</div>
    <% } %>
  </main>
  <%- include('../partials/nav') %>
  <script src="/js/vendors.js"></script>
</body>
</html>
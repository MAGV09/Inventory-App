<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
  <main>
    <a href="/vendors" class="back-link">Vendors</a>
    <div style="margin-bottom:32px;">
      <span class="page-label">New Vendor</span>
      <h1>Add Vendor</h1>
    </div>
    <div class="form-card">
      <form method="post" action="/vendors/create">
        <div class="form-group">
          <label class="form-label">Vendor Name</label>
          <input type="text" name="name" placeholder="e.g. TechSupply Co." required>
        </div>
        <div class="form-group">
          <label class="form-label">Location</label>
          <input type="text" name="location" placeholder="e.g. New York, USA">
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">Add Vendor</button>
      </form>
    </div>
  </main>
  <%- include('../partials/nav') %>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
  <main>
    <a href="/vendors" class="back-link">Vendors</a>
    <div style="margin-bottom:32px;">
      <span class="page-label"><%= vendor.name %></span>
      <h1>Add Product</h1>
    </div>
    <% if(products && products.length){ %>
      <div class="form-card">
        <form method="post" action="/vendors/<%= vendor.id %>/add-product">
          <div class="form-group">
            <label class="form-label">Product</label>
            <select name="product_id" required>
              <option value="">Select Product</option>
              <% products.forEach(product => { %>
                <option value="<%= product.id %>"><%= product.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Unit Cost ($)</label>
            <input type="number" name="unit_cost" placeholder="0.00" step="0.01" min="0" required>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;">Link Product</button>
        </form>
      </div>
    <% } else { %>
      <div class="empty">All products are already linked to this vendor</div>
    <% } %>
  </main>
  <%- include('../partials/nav') %>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
  <main>
    <a href="/brands" class="back-link">Brands</a>
    <div style="margin-bottom:32px;">
      <span class="page-label">New Brand</span>
      <h1>Add Brand</h1>
    </div>
    <div class="form-card">
      <form method="post" action="/brands/create">
        <div class="form-group">
          <label class="form-label">Brand Name</label>
          <input type="text" name="name" placeholder="e.g. Nvidia" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">Add Brand</button>
      </form>
    </div>
  </main>
  <%- include('../partials/nav') %>
</body>
</html>
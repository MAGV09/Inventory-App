<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
  <main>
    <a href="/products" class="back-link">Products</a>
    <div style="margin-bottom:32px;">
      <span class="page-label">Edit Entry</span>
      <h1><%= product.name %></h1>
    </div>
    <div class="form-card">
      <form id="update-product-form" data-id="<%= product.id %>">
        <div class="form-group">
          <label class="form-label">Product Name</label>
          <input type="text" name="name" value="<%= product.name %>" required>
        </div>
        <div class="form-group">
          <label class="form-label">Category</label>
          <select name="category_id" required>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>" <%= product.category === cat.name ? 'selected' : '' %>>
                <%= cat.name %>
              </option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Brand</label>
          <select name="brand_id" required>
            <% brands.forEach(brand => { %>
              <option value="<%= brand.id %>" <%= product.brand === brand.name ? 'selected' : '' %>>
                <%= brand.name %>
              </option>
            <% }); %>
          </select>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">Save Changes</button>
      </form>
    </div>
  </main>
  <%- include('../partials/nav') %>
  <script src="/js/products.js"></script>
</body>
</html>